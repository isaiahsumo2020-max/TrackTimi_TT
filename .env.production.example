# Production Environment Configuration
# Copy this to backend/.env and fill in your production values

# Node Environment
NODE_ENV=production
PORT=4000

# Security
JWT_SECRET=your-super-secure-secret-here-at-least-32-characters-long

# Frontend Configuration
FRONTEND_URL=https://your-production-domain.com
MAIN_DOMAIN=your-production-domain.com

# Database
DB_PATH=/var/lib/tracktimi/data/tracktimi.db

# Email Configuration (Gmail with App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM=noreply@your-domain.com

# Optional: Other Email Services
# EMAIL_SERVICE=sendgrid
# EMAIL_API_KEY=your-sendgrid-api-key

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/tracktimi/app.log

# CORS Settings
ALLOWED_ORIGINS=https://your-production-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Sentry Error Tracking
# SENTRY_DSN=https://your-sentry-dsn

# Optional: Analytics
# ANALYTICS_ENABLED=true
# ANALYTICS_KEY=your-analytics-key
